# ─── Server ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/soulmate_sync?schema=public"

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ───────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_token_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_RESET_SECRET=your_super_secret_reset_token_key_min_32_chars
JWT_RESET_EXPIRY=1h

# ─── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.com

# ─── Cloudinary ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=matrimony_profiles

# ─── AWS S3 (Alternative to Cloudinary) ───────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=soulmate-sync-photos

# ─── Email (SMTP / Nodemailer) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@soulmatesync.com
SMTP_PASS=your_email_app_password
EMAIL_FROM="Soulmate Sync <noreply@soulmatesync.com>"

# ─── SMS (Twilio / MSG91) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# OR MSG91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=SMTSYN
MSG91_TEMPLATE_ID=your_template_id

# ─── WebRTC / TURN Server ──────────────────────────────────────────────
TURN_SERVER_URL=turn:your.turn.server:3478
TURN_SERVER_USERNAME=username
TURN_SERVER_CREDENTIAL=password
STUN_SERVER_URL=stun:stun.l.google.com:19302

# ─── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Security ──────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
COOKIE_SECRET=your_cookie_secret_key

# ─── Pagination ────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ─── Admin ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@soulmatesync.com
ADMIN_PASSWORD=Admin@SecurePass123
